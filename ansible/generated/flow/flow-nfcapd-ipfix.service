[Unit]
Description=IPFIX capture daemon for nfsen-ng (%i)
Documentation=man:nfcapd(1)
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
User=www-data
Group=www-data
RuntimeDirectory=flow-nfcapd-ipfix
ExecStart=/usr/bin/nfcapd -D -P /run/flow-nfcapd-ipfix/capture.pid -z -S 1 -T all -l /var/nfdump/profiles-data/live/ipfix -p 4739
PIDFile=/run/flow-nfcapd-ipfix/capture.pid
Restart=on-failure
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
