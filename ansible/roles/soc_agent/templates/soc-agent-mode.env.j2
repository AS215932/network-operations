# Deploy path: {{ soc_agent_mode_env_file }}
# Non-secret SOC mode/kill-switch environment, rendered by Ansible
# (roles/soc_agent). Secrets are rendered separately by Vault Agent into
# {{ soc_agent_secrets_env_file }} (optional in shadow mode).
#
# SOC_MODE ladder + promotion criteria: docs/runbooks/soc-mode-promotion.md

SOC_ENABLED={{ '1' if soc_enabled | bool else '0' }}
SOC_MODE={{ soc_mode }}
SOC_POSTURE_ENABLED={{ '1' if soc_posture_enabled | bool else '0' }}

# Kill switches / hard rails (redteam-safety-policy.md): active probes stay
# off in v1; case verification ships dry-run.
SOC_REDTEAM_ENABLED={{ '1' if soc_redteam_enabled | bool else '0' }}
SOC_REDTEAM_ALLOW_ACTIVE_PROBES=0
SOC_LHP_ENABLED={{ '1' if soc_lhp_enabled | bool else '0' }}
SOC_CASE_VERIFICATION_DRY_RUN={{ '1' if soc_case_verification_dry_run | bool else '0' }}
SOC_POSTURE_HANDOFF_ENABLED={{ '1' if soc_posture_handoff_enabled | bool else '0' }}

# Desired-state checkout the posture scanner audits against (managed by the
# soc_agent role, pinned like the app checkout).
SOC_NETWORK_OPERATIONS_DIR={{ soc_network_operations_dir }}
{% if soc_network_operations_version is match('^[0-9a-f]{40}$') %}
SOC_NETWORK_OPERATIONS_PIN_SHA={{ soc_network_operations_version }}
{% endif %}

# Live-state queries go through hyrule-mcp; the app requires a URL or a
# stdio command (exactly one set in host_vars).
{% if soc_hyrule_mcp_url | length > 0 %}
HYRULE_MCP_URL={{ soc_hyrule_mcp_url }}
{% endif %}
{% if soc_hyrule_mcp_cmd | length > 0 %}
HYRULE_MCP_CMD={{ soc_hyrule_mcp_cmd }}
{% endif %}

# Insight stream (agent-core loop decision envelopes) toward the collector.
HYRULE_SOC_AGENT_CORE_TRACE={{ '1' if soc_agent_core_trace_enabled | bool else '0' }}
HYRULE_SOC_AGENT_CORE_TRACE_COLLECTOR_URL={{ soc_agent_core_trace_collector_url }}
