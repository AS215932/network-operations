# Managed by ansible/roles/github_runner
[Unit]
Description=GitHub Actions runner ({{ github_runner_name }})
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ github_runner_user }}
Group={{ github_runner_group }}
WorkingDirectory={{ github_runner_install_dir }}
ExecStart={{ github_runner_install_dir }}/run.sh
# run.sh exits 0 when the runner self-updates or is reconfigured; on-failure
# would leave the service dead after that. always — matches GitHub's own
# generated unit — so the runner comes back regardless of exit code.
Restart=always
RestartSec=5s
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=5min
Environment=HOME={{ github_runner_home }}

# Hardening
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths={{ github_runner_install_dir }} {{ github_runner_home }} /tmp /var/tmp
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=multi-user.target
