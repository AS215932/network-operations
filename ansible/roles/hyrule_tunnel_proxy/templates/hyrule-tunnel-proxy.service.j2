# /etc/systemd/system/hyrule-tunnel-proxy.service
# Managed by Ansible.

[Unit]
Description=Hyrule Tunnel Proxy (public reverse-SSH tunnel)
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User={{ hyrule_tunnel_proxy_user }}
Group={{ hyrule_tunnel_proxy_group }}
EnvironmentFile={{ hyrule_tunnel_proxy_env_file }}
ExecStart={{ hyrule_tunnel_proxy_bin_path }}
Restart=always
RestartSec=5
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths={{ hyrule_tunnel_proxy_state_dir }}
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hyrule-tunnel-proxy

[Install]
WantedBy=multi-user.target
