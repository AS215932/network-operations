// /etc/icinga2/conf.d/hosts/ansible/{{ inventory_hostname }}.conf
// Managed by ansible/roles/monitoring — do not edit by hand.
// Source of truth: ansible/inventory/host_vars/{{ inventory_hostname }}.yml

object Host "{{ inventory_hostname }}" {
{% if peers[inventory_hostname].ipv4 is defined %}
  address  = "{{ peers[inventory_hostname].ipv4 }}"
{% endif %}
{% if peers[inventory_hostname].ipv6 is defined %}
  address6 = "{{ peers[inventory_hostname].ipv6 }}"
{% elif peers[inventory_hostname].loopback is defined %}
  address6 = "{{ peers[inventory_hostname].loopback }}"
{% endif %}
  display_name = "{{ monitoring_display_name | default(inventory_hostname) }}"

{% if monitoring_check_command is defined %}
  check_command = "{{ monitoring_check_command }}"
{% elif peers[inventory_hostname].ipv6 is defined or peers[inventory_hostname].loopback is defined %}
  check_command = "ping6"
{% else %}
  check_command = "ping4"
{% endif %}

  vars.os = "{{ ansible_os_family | default('Debian') }}"
  vars.role = "{{ monitoring_role | default('infra') }}"
{% if monitoring_ssh_check | default(true) %}
  vars.ssh_port = 22
{% if monitoring_ssh_address is defined %}
  vars.ssh_address = "{{ monitoring_ssh_address }}"
{% endif %}
{% if monitoring_ssh_ipv6 | default(false) %}
  vars.ssh_ipv6 = true
{% endif %}
{% endif %}
{% if monitoring_check_vars is defined %}
{% for k, v in monitoring_check_vars.items() %}
{% if v is boolean %}
  vars.{{ k }} = {{ v | lower }}
{% elif v is string %}
  vars.{{ k }} = {{ v | to_json }}
{% elif v is mapping %}
  vars.{{ k }} = { {% for kk, vv in v.items() %}{{ kk }} = {{ vv | to_json }}{% if not loop.last %}, {% endif %}{% endfor %} }
{% else %}
  vars.{{ k }} = {{ v }}
{% endif %}
{% endfor %}
{% endif %}

{# Prometheus instance for node-up + disk apply rules. #}
{% set scrape_addr = peers[inventory_hostname].ipv6 | default(peers[inventory_hostname].loopback) | default(peers[inventory_hostname].ipv4) %}
{% if ':' in scrape_addr %}
  vars.prom_instance_node = "[{{ scrape_addr }}]:9100"
{% else %}
  vars.prom_instance_node = "{{ scrape_addr }}:9100"
{% endif %}

{# Disks — drives the disk.conf apply Service #}
{% for disk_name, disk_cfg in monitoring_disks.items() %}
  vars.disks["{{ disk_name }}"] = { mountpoint = "{{ disk_cfg.mountpoint }}" }
{% endfor %}
}
{% if monitoring_extra_services | default([]) %}

{# Per-service blocks (service-specific checks not covered by the global apply rules). #}
{% for svc in monitoring_extra_services %}
object Service "{{ svc.name }}" {
  host_name = "{{ inventory_hostname }}"
  check_command = "{{ svc.check_command }}"
  check_interval = {{ svc.interval | default('2m') }}
  retry_interval = {{ svc.retry | default('30s') }}
{% if svc.max_check_attempts is defined %}
  max_check_attempts = {{ svc.max_check_attempts }}
{% endif %}
{% if svc.enable_active_checks is defined %}
  enable_active_checks = {{ svc.enable_active_checks | lower }}
{% endif %}
{% if svc.enable_passive_checks is defined %}
  enable_passive_checks = {{ svc.enable_passive_checks | lower }}
{% endif %}
{% if svc.enable_flapping is defined %}
  enable_flapping = {{ svc.enable_flapping | lower }}
{% endif %}
{% if svc.flapping_threshold_low is defined %}
  flapping_threshold_low = {{ svc.flapping_threshold_low }}
{% endif %}
{% if svc.flapping_threshold_high is defined %}
  flapping_threshold_high = {{ svc.flapping_threshold_high }}
{% endif %}
{% if svc.notes is defined %}
  notes = "{{ svc.notes }}"
{% endif %}
{% if svc.vars is defined %}
{% for k, v in svc.vars.items() %}
{% if v is boolean %}
  vars.{{ k }} = {{ v | lower }}
{% elif v is string %}
  vars.{{ k }} = {{ v | to_json }}
{% elif v is mapping %}
  vars.{{ k }} = { {% for kk, vv in v.items() %}{{ kk }} = {{ vv | to_json }}{% if not loop.last %}, {% endif %}{% endfor %} }
{% else %}
  vars.{{ k }} = {{ v }}
{% endif %}
{% endfor %}
{% endif %}
}

{% endfor %}
{% endif %}
