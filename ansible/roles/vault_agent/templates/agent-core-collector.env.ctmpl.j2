# /etc/agent-core-collector/collector.env
# Rendered by Vault Agent from kv/data/agent-core-collector. Do not edit by hand.
# Secret scope: collector-local Postgres password only.

{% raw %}{{ with secret "kv/data/agent-core-collector" -}}
AGENT_CORE_COLLECTOR_DB_PASSWORD={{ .Data.data.db_password }}
HYRULE_COLLECTOR_DATABASE_URL=postgresql+asyncpg://agent_core_collector:{{ .Data.data.db_password }}@127.0.0.1:5432/agent_core_collector
# Bearer for authenticated ingest. Empty => unauthenticated (current
# behaviour); this render stays inert until the secret is set.
#
# DO NOT set kv/agent-core-collector ingest_token until AS215932/network-
# operations#422 lands. In collector v0.8.0 the guard is unconditional on
# POST /v1/trace + /v1/trace/batch (app.py:384,394), and labels share that
# endpoint with the trace firehose — so a token here would also 401 the
# noc/engineering/knowledge trace producers (silently: HttpSink swallows the
# error), starving the insight stream. #422 scopes the guard to insight_label
# writes; only then mint this + kv/agentic-observatory collector_ingest_token.
HYRULE_COLLECTOR_INGEST_TOKEN={{ or .Data.data.ingest_token "" }}
{{- end }}{% endraw %}
