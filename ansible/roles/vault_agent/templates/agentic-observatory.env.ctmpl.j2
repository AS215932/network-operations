{{ '{{ with secret "kv/data/agentic-observatory" }}' }}
OBSERVATORY_ENVIRONMENT=production
OBSERVATORY_BASE_URL=https://{{ agentic_observatory_domain }}
OBSERVATORY_SESSION_SECRET={{ '{{ .Data.data.session_secret }}' }}
OBSERVATORY_CSRF_SECRET={{ '{{ .Data.data.csrf_secret }}' }}
OBSERVATORY_OPERATOR_USERNAME={{ '{{ .Data.data.operator_username }}' }}
OBSERVATORY_OPERATOR_PASSWORD_HASH={{ '{{ .Data.data.operator_password_hash }}' }}
OBSERVATORY_DB_PASSWORD={{ '{{ .Data.data.db_password }}' }}
OBSERVATORY_DATABASE_URL=postgresql+asyncpg://{{ agentic_observatory_database_role }}:{{ '{{ .Data.data.db_password }}' }}@{{ agentic_observatory_database_host }}/{{ agentic_observatory_database_name }}
OBSERVATORY_COLLECTOR_BASE_URL={{ agentic_observatory_collector_base_url }}
# Bearer for posting InsightLabels to the collector. Empty => the label action
# fails closed (read-only inbox still works). Set kv/agentic-observatory
# collector_ingest_token to the same value as the collector's ingest_token —
# but only after AS215932/network-operations#422 scopes the collector guard to
# label writes, else the shared token also breaks trace ingest (see #422).
OBSERVATORY_COLLECTOR_INGEST_TOKEN={{ '{{ or .Data.data.collector_ingest_token "" }}' }}
OBSERVATORY_NOC_BASE_URL={{ agentic_observatory_noc_base_url }}
OBSERVATORY_NOC_LOOP_CONSOLE_SECRET={{ '{{ .Data.data.noc_loop_console_secret }}' }}
OBSERVATORY_GITHUB_TOKEN={{ '{{ .Data.data.github_token }}' }}
OBSERVATORY_GITHUB_OAUTH_CLIENT_ID={{ '{{ or .Data.data.github_oauth_client_id "" }}' }}
OBSERVATORY_GITHUB_OAUTH_CLIENT_SECRET={{ '{{ or .Data.data.github_oauth_client_secret "" }}' }}
OBSERVATORY_GITHUB_OAUTH_POLICY_TOKEN={{ '{{ or .Data.data.github_oauth_policy_token "" }}' }}
OBSERVATORY_GITHUB_OAUTH_ORG={{ agentic_observatory_github_oauth_org }}
OBSERVATORY_GITHUB_OAUTH_OPS_TEAM_SLUG={{ agentic_observatory_github_oauth_ops_team_slug }}
OBSERVATORY_GITHUB_OAUTH_REQUIRE_ORG_2FA={{ agentic_observatory_github_oauth_require_org_2fa | bool | ternary('true', 'false') }}
OBSERVATORY_COORDINATOR_BASE_URL={{ agentic_observatory_coordinator_base_url if agentic_observatory_coordinator_enabled | bool else '' }}
OBSERVATORY_COORDINATOR_KEY_ID={{ agentic_observatory_coordinator_key_id }}
OBSERVATORY_COORDINATOR_SECRET={{ '{{ or .Data.data.coordinator_secret "" }}' }}
OBSERVATORY_READ_ONLY={{ agentic_observatory_read_only | bool | ternary('true', 'false') }}
OBSERVATORY_ACTIONS_ENABLED={{ agentic_observatory_actions_enabled | bool | ternary('true', 'false') }}
OBSERVATORY_ENABLED_ACTIONS={{ agentic_observatory_enabled_actions }}
{{ '{{ end }}' }}
