# {{ vault_agent_config_dir }}/{{ vault_agent_name }}.hcl
# Managed by ansible/roles/vault_agent.

pid_file = "{{ vault_agent_run_dir }}/{{ vault_agent_name }}.pid"

vault {
  address = "{{ vault_agent_vault_addr }}"
{% if vault_agent_vault_tls_skip_verify | bool %}
  tls_skip_verify = true
{% endif %}

  retry {
    num_retries = 12
  }
}

auto_auth {
  method "approle" {
    mount_path = "auth/approle"

    config = {
      role_id_file_path = "{{ vault_agent_role_id_file }}"
      secret_id_file_path = "{{ vault_agent_secret_id_file }}"
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "{{ vault_agent_token_sink }}"
      mode = 0600
    }
  }
}

{% for t in vault_agent_templates %}
template {
  source      = "{{ vault_agent_template_dir }}/{{ t.name }}"
  destination = "{{ t.destination }}"
  perms       = 0640
  command     = "/bin/sh -c 'chgrp {{ t.group }} {{ t.destination }} && chmod 0640 {{ t.destination }} && {{ t.reload_command }}'"

  wait {
    min = "2s"
    max = "10s"
  }
}
{% if not loop.last %}

{% endif %}
{% endfor %}
