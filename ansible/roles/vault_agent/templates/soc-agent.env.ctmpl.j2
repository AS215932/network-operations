# /opt/soc-agent/.env
# Rendered by Vault Agent from kv/data/soc-agent — SECRETS ONLY. Do not edit
# by hand. Non-secret SOC_MODE/kill-switch env is rendered by the soc_agent
# role into /etc/soc-agent/soc-agent.env; systemd units load both. Wire this
# template through the vault_agent role's `vault_agent_templates` list in the
# SOC host's play (mirroring noc.yml) when the host first schedules
# playbooks/soc.yml.

{% raw %}{{ with secret "kv/data/soc-agent" -}}
OPENROUTER_API_KEY={{ or .Data.data.openrouter_api_key "" }}
DISCORD_WEBHOOK_URL={{ or .Data.data.discord_webhook_url "" }}
SOC_LHP_ENGINEERING_SECRET={{ or .Data.data.soc_lhp_engineering_secret "" }}
ICINGA_API_USER={{ or .Data.data.icinga_api_user "" }}
ICINGA_API_PASSWORD={{ or .Data.data.icinga_api_password "" }}
{{- end }}{% endraw %}
