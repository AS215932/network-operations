# /opt/soc-agent/.env
# Rendered by Vault Agent from kv/data/soc-agent. Do not edit by hand.

{% raw %}{{ with secret "kv/data/soc-agent" -}}
OPENROUTER_API_KEY={{ or .Data.data.openrouter_api_key "" }}
DISCORD_WEBHOOK_URL={{ or .Data.data.discord_webhook_url "" }}
SOC_LHP_ENGINEERING_SECRET={{ or .Data.data.soc_lhp_engineering_secret "" }}
ICINGA_API_USER={{ or .Data.data.icinga_api_user "" }}
ICINGA_API_PASSWORD={{ or .Data.data.icinga_api_password "" }}
{{- end }}{% endraw %}

# --- SOC_MODE rollout ladder (docs/runbooks/soc-mode-promotion.md) ----------
# Rung changes are reviewed promotion PRs editing soc_mode in host_vars; the
# insight-metrics criteria for each rung are in the runbook.
SOC_ENABLED={{ '1' if soc_enabled | default(true) else '0' }}
SOC_MODE={{ soc_mode | default('shadow') }}
SOC_POSTURE_ENABLED={{ '1' if soc_posture_enabled | default(true) else '0' }}

# Kill switches / hard rails (redteam-safety-policy.md): active probes stay
# off in v1; case verification ships dry-run.
SOC_REDTEAM_ENABLED={{ '1' if soc_redteam_enabled | default(false) else '0' }}
SOC_REDTEAM_ALLOW_ACTIVE_PROBES=0
SOC_LHP_ENABLED={{ '1' if soc_lhp_enabled | default(false) else '0' }}
SOC_CASE_VERIFICATION_DRY_RUN={{ '1' if soc_case_verification_dry_run | default(true) else '0' }}

# Insight stream (agent-core loop decision envelopes) — SOC's emitter is
# already wired; point it at the collector on loop.
HYRULE_SOC_AGENT_CORE_TRACE={{ '1' if soc_agent_core_trace_enabled | default(false) else '0' }}
HYRULE_SOC_AGENT_CORE_TRACE_COLLECTOR_URL={{ soc_agent_core_trace_collector_url | default('') }}
