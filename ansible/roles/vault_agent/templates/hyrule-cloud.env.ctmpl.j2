PAYMENT_PRICE_BGP_ROUTER_TABLE={{ or .Data.data.payment_price_bgp_router_table "0.10" }}
PAYMENT_PRICE_BGP_ROUTER_TABLE_ALL={{ or .Data.data.payment_price_bgp_router_table_all "0.25" }}
