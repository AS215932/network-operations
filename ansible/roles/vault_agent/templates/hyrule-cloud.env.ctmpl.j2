# Dev bypass — set a random secret for staging, leave EMPTY for production
PAYMENT_DEV_BYPASS_SECRET={{ or .Data.data.dev_bypass_secret "" }}

# --- Hyrule ---
HYRULE_DEPLOY_DOMAIN=deploy.hyrule.host
# Canonical public origin for x402 402-response resource URLs (Bazaar identity)
HYRULE_PUBLIC_BASE_URL=https://cloud.hyrule.host
HYRULE_IP_PREFIX_PEPPER={{ .Data.data.ip_prefix_pepper }}
HYRULE_NETWORK_PROXY_URL=http://[2a0c:b641:b50:2::e0]:8450
HYRULE_NETWORK_PROXY_TOKEN={{ or .Data.data.network_proxy_token "" }}
HYRULE_NETWORK_PROXY_HEALTH_TTL_SECONDS=15
HYRULE_BGP_DATA_ENABLED=true
HYRULE_BGP_DATA_DIR=/var/lib/hyrule-cloud/bgp
HYRULE_BGP_INGEST_TOKEN={{ or .Data.data.bgp_ingest_token "" }}
HYRULE_CUSTOMER_IPV6_SUPERNET={{ or .Data.data.customer_ipv6_supernet "2a0c:b641:b51::/48" }}
HYRULE_CUSTOMER_IPV6_GATEWAY={{ or .Data.data.customer_ipv6_gateway "2a0c:b641:b51::1" }}
HYRULE_CUSTOMER_IPV6_DNS={{ or .Data.data.customer_ipv6_dns "2a0c:b641:b51::1" }}

# DNS (RFC 2136 dynamic updates to Knot DNS)
HYRULE_DNS_SERVER=2a0c:b641:b50:2::10
HYRULE_DNS_TSIG_KEY={{ .Data.data.tsig_secret }}
HYRULE_DNS_TSIG_ALGO=hmac-sha256

# VM lifecycle
HCP_LAUNCH_PROOF_REAL_XCPNG={{ or .Data.data.hcp_launch_proof_real_xcpng "1" }}
# Fail-fast guard: refuse to boot while provisioning is simulated or the dev
# bypass is set. Keep 1 in production; kv-set 0 only for staging experiments.
HYRULE_REQUIRE_REAL_PROVISIONING={{ or .Data.data.require_real_provisioning "1" }}
HYRULE_VM_GRACE_PERIOD_HOURS=48
HYRULE_MAX_PAID_ACTIVE_VMS=10
HYRULE_MAX_DURATION_DAYS=365
HYRULE_MAX_PORTS=10
HYRULE_BLOCKED_PORTS=[25,465,587]

# Observability: bearer token mon's Prometheus uses to scrape /metrics, and
# the Prometheus URL for /v1/stats/network fleet stats (empty = static fallback)
HYRULE_METRICS_TOKEN={{ or .Data.data.metrics_token "" }}
HYRULE_PROMETHEUS_URL={{ or .Data.data.prometheus_url "" }}

# Database (PostgreSQL on localhost via IPv6 loopback)
HYRULE_DATABASE_URL=postgresql+asyncpg://hyrule:{{ .Data.data.db_password }}@localhost/hyrule?ssl=disable
