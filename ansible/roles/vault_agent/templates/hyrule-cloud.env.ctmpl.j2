# /opt/hyrule-cloud/.env
# Rendered by Vault Agent from kv/data/hyrule-cloud. Do not edit by hand.

{% raw %}{{ with secret "kv/data/hyrule-cloud" -}}
# --- Xen Orchestra (WebSocket JSON-RPC) ---
# All XCP-NG operations go through XO. XO proxies XAPI calls internally.
XCPNG_XO_URL=wss://xo.servify.network/api/
XCPNG_XO_TOKEN={{ .Data.data.xo_token }}
XCPNG_XO_VERIFY_SSL=true

# --- Storage & Network ---
XCPNG_DEFAULT_SR_UUID={{ .Data.data.sr_uuid }}
XCPNG_DEFAULT_NETWORK_UUID={{ .Data.data.vm_network_uuid }}

# --- Templates (JSON dict: {"os-name": "template-uuid"}) ---
XCPNG_TEMPLATES={{ or .Data.data.xcpng_templates "{\"debian-13\":\"\"}" }}

# --- OpenBSD offline root resize builder ---
XCPNG_OPENBSD_BUILDER_VM_UUID={{ or .Data.data.xcpng_openbsd_builder_vm_uuid "" }}
XCPNG_OPENBSD_BUILDER_SSH_HOST={{ or .Data.data.xcpng_openbsd_builder_ssh_host "" }}
XCPNG_OPENBSD_BUILDER_SSH_USER={{ or .Data.data.xcpng_openbsd_builder_ssh_user "svag" }}
XCPNG_OPENBSD_BUILDER_SSH_KEY_PATH={{ or .Data.data.xcpng_openbsd_builder_ssh_key_path "/run/secrets/openbsd_builder_ssh_key" }}
XCPNG_OPENBSD_BUILDER_DISK_DEVICE={{ or .Data.data.xcpng_openbsd_builder_disk_device "sd1" }}
XCPNG_OPENBSD_BUILDER_ATTACH_POSITION={{ or .Data.data.xcpng_openbsd_builder_attach_position "1" }}

# --- Openprovider ---
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME={{ .Data.data.openprovider_username }}
OPENPROVIDER_PASSWORD={{ .Data.data.openprovider_password }}
OPENPROVIDER_OWNER_HANDLE={{ .Data.data.openprovider_owner_handle }}
OPENPROVIDER_ADMIN_HANDLE={{ .Data.data.openprovider_admin_handle }}
OPENPROVIDER_TECH_HANDLE={{ .Data.data.openprovider_tech_handle }}
OPENPROVIDER_BILLING_HANDLE={{ .Data.data.openprovider_billing_handle }}
OPENPROVIDER_NAMESERVERS={{ or .Data.data.openprovider_nameservers "[\"ns1.openprovider.nl\",\"ns2.openprovider.be\",\"ns3.openprovider.eu\"]" }}

# --- x402 Payments ---
PAYMENT_RECEIVER_ADDRESS={{ .Data.data.payment_wallet }}
PAYMENT_FACILITATOR_URL=https://x402.org/facilitator
PAYMENT_NETWORK=eip155:8453
PAYMENT_ASSET=USDC
PAYMENT_REQUIRE_NATIVE=true
PAYMENT_BTC_XPUB={{ .Data.data.btc_xpub }}
PAYMENT_XMR_VIEWKEY={{ .Data.data.xmr_viewkey }}
PAYMENT_XMR_RPC_URL={{ or .Data.data.xmr_rpc_url "http://127.0.0.1:18088/json_rpc" }}

# Pricing (USD per day)
PAYMENT_PRICE_VM_XS=0.05
PAYMENT_PRICE_VM_SM=0.10
PAYMENT_PRICE_VM_MD=0.20
PAYMENT_PRICE_VM_LG=0.40
PAYMENT_PRICE_VPN=0.02
PAYMENT_PRICE_DOMAIN_MARKUP=1.00
PAYMENT_PRICE_PROXY_DIRECT=0.01
PAYMENT_PRICE_PROXY_TOR=0.05
PAYMENT_PRICE_PROXY_I2P=0.05
PAYMENT_PRICE_PROXY_YGGDRASIL=0.03
PAYMENT_PRICE_BGP_LOOKUP={{ or .Data.data.payment_price_bgp_lookup "0.005" }}
PAYMENT_PRICE_BGP_ROUTER_QUERY={{ or .Data.data.payment_price_bgp_router_query "0.01" }}
PAYMENT_PRICE_BGPSTREAM_HOUR={{ or .Data.data.payment_price_bgpstream_hour "0.05" }}
PAYMENT_PRICE_BGPSTREAM_RIB={{ or .Data.data.payment_price_bgpstream_rib "0.10" }}
PAYMENT_PRICE_BGP_ROUTER_TABLE={{ or .Data.data.payment_price_bgp_router_table "0.10" }}
PAYMENT_PRICE_BGP_ROUTER_TABLE_ALL={{ or .Data.data.payment_price_bgp_router_table_all "0.25" }}
PAYMENT_PRICE_IP_LOOKUP={{ or .Data.data.payment_price_ip_lookup "0.003" }}
PAYMENT_PRICE_DNS_LOOKUP={{ or .Data.data.payment_price_dns_lookup "0.001" }}
PAYMENT_PRICE_RDAP_LOOKUP={{ or .Data.data.payment_price_rdap_lookup "0.003" }}
PAYMENT_PRICE_WHOIS_LOOKUP={{ or .Data.data.payment_price_whois_lookup "0.005" }}
PAYMENT_PRICE_MX_CHECK={{ or .Data.data.payment_price_mx_check "0.005" }}
PAYMENT_PRICE_MX_REPORT={{ or .Data.data.payment_price_mx_report "0.03" }}
PAYMENT_PRICE_WEB_CHECK={{ or .Data.data.payment_price_web_check "0.005" }}
PAYMENT_PRICE_WEB_REPORT={{ or .Data.data.payment_price_web_report "0.03" }}
PAYMENT_PRICE_WEB_TLS_DEEP={{ or .Data.data.payment_price_web_tls_deep "0.10" }}
PAYMENT_PRICE_PATH_PROBE={{ or .Data.data.payment_price_path_probe "0.005" }}
PAYMENT_PRICE_PATH_REPORT={{ or .Data.data.payment_price_path_report "0.05" }}
PAYMENT_PRICE_PORT_CHECK={{ or .Data.data.payment_price_port_check "0.003" }}
PAYMENT_PRICE_NAT_LOOKUP={{ or .Data.data.payment_price_nat_lookup "0.003" }}
PAYMENT_PRICE_NAT_PORT_FORWARD_CHECK={{ or .Data.data.payment_price_nat_port_forward_check "0.005" }}
PAYMENT_PRICE_THREAT_LOOKUP={{ or .Data.data.payment_price_threat_lookup "0.01" }}
PAYMENT_PRICE_VOIP_CHECK={{ or .Data.data.payment_price_voip_check "0.01" }}
PAYMENT_PRICE_VOIP_NUMBER_LOOKUP={{ or .Data.data.payment_price_voip_number_lookup "0.05" }}
PAYMENT_PRICE_VOIP_REPORT={{ or .Data.data.payment_price_voip_report "0.08" }}
PAYMENT_PRICE_SPEEDTEST={{ or .Data.data.payment_price_speedtest "0.10" }}
PAYMENT_PRICE_MAIL_AGENT_BASIC_DAY={{ or .Data.data.payment_price_mail_agent_basic_day "0.05" }}
PAYMENT_PRICE_MAIL_STORAGE_GB_DAY={{ or .Data.data.payment_price_mail_storage_gb_day "0.01" }}
PAYMENT_PRICE_MAIL_OUTBOUND_MESSAGE={{ or .Data.data.payment_price_mail_outbound_message "0.001" }}

# Dev bypass — set a random secret for staging, leave EMPTY for production
PAYMENT_DEV_BYPASS_SECRET={{ or .Data.data.dev_bypass_secret "" }}

# --- Hyrule ---
HYRULE_DEPLOY_DOMAIN=deploy.hyrule.host
HYRULE_IP_PREFIX_PEPPER={{ .Data.data.ip_prefix_pepper }}
HYRULE_NETWORK_PROXY_URL=http://[2a0c:b641:b50:2::e0]:8450
HYRULE_NETWORK_PROXY_TOKEN={{ or .Data.data.network_proxy_token "" }}
HYRULE_NETWORK_PROXY_HEALTH_TTL_SECONDS=15
HYRULE_BGP_DATA_ENABLED=true
HYRULE_BGP_DATA_DIR=/var/lib/hyrule-cloud/bgp
HYRULE_BGP_INGEST_TOKEN={{ or .Data.data.bgp_ingest_token "" }}

# DNS (RFC 2136 dynamic updates to Knot DNS)
HYRULE_DNS_SERVER=2a0c:b641:b50:2::10
HYRULE_DNS_TSIG_KEY={{ .Data.data.tsig_secret }}
HYRULE_DNS_TSIG_ALGO=hmac-sha256

# VM lifecycle
HYRULE_VM_GRACE_PERIOD_HOURS=48
HYRULE_MAX_PAID_ACTIVE_VMS=10
HYRULE_MAX_DURATION_DAYS=365
HYRULE_MAX_PORTS=10
HYRULE_BLOCKED_PORTS=[25,465,587]

# Database (PostgreSQL on localhost via IPv6 loopback)
HYRULE_DATABASE_URL=postgresql+asyncpg://hyrule:{{ .Data.data.db_password }}@localhost/hyrule?ssl=disable
{{- end }}{% endraw %}
