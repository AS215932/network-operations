# /opt/hyrule-cloud/.env
# Rendered by Vault Agent from kv/data/hyrule-cloud. Do not edit by hand.

{% raw %}{{ with secret "kv/data/hyrule-cloud" -}}
# --- Xen Orchestra (WebSocket JSON-RPC) ---
# All XCP-NG operations go through XO. XO proxies XAPI calls internally.
XCPNG_XO_URL=wss://xo.servify.network/api/
XCPNG_XO_TOKEN={{ .Data.data.xo_token }}
XCPNG_XO_VERIFY_SSL=true

# --- Storage & Network ---
XCPNG_DEFAULT_SR_UUID={{ .Data.data.sr_uuid }}
XCPNG_DEFAULT_NETWORK_UUID={{ .Data.data.vm_network_uuid }}
# Admission control: 2:1 CPU, no RAM overcommit, preserve recovery headroom.
XCPNG_VCPU_OVERCOMMIT_RATIO=2.0
XCPNG_MEMORY_HEADROOM_MB=2048
XCPNG_STORAGE_HEADROOM_GB=20

# --- Templates (JSON dict: {"os-name": "template-uuid"}) ---
XCPNG_TEMPLATES={{ or .Data.data.xcpng_templates "{\"debian-13\":\"\"}" }}

# --- OpenBSD offline root resize builder ---
XCPNG_OPENBSD_BUILDER_VM_UUID={{ or .Data.data.xcpng_openbsd_builder_vm_uuid "" }}
XCPNG_OPENBSD_BUILDER_SSH_HOST={{ or .Data.data.xcpng_openbsd_builder_ssh_host "" }}
XCPNG_OPENBSD_BUILDER_SSH_USER={{ or .Data.data.xcpng_openbsd_builder_ssh_user "svag" }}
XCPNG_OPENBSD_BUILDER_SSH_KEY_PATH={{ or .Data.data.xcpng_openbsd_builder_ssh_key_path "/run/secrets/openbsd_builder_ssh_key" }}
XCPNG_OPENBSD_BUILDER_DISK_DEVICE={{ or .Data.data.xcpng_openbsd_builder_disk_device "sd1" }}
XCPNG_OPENBSD_BUILDER_ATTACH_POSITION={{ or .Data.data.xcpng_openbsd_builder_attach_position "1" }}

# --- Openprovider ---
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME={{ .Data.data.openprovider_username }}
OPENPROVIDER_PASSWORD={{ .Data.data.openprovider_password }}
OPENPROVIDER_OWNER_HANDLE={{ .Data.data.openprovider_owner_handle }}
OPENPROVIDER_ADMIN_HANDLE={{ .Data.data.openprovider_admin_handle }}
OPENPROVIDER_TECH_HANDLE={{ .Data.data.openprovider_tech_handle }}
OPENPROVIDER_BILLING_HANDLE={{ .Data.data.openprovider_billing_handle }}
OPENPROVIDER_NAMESERVERS={{ or .Data.data.openprovider_nameservers "[\"ns1.hyrule.host\",\"ns2.hyrule.host\"]" }}

# --- Managed customer domains ---
# Account checkout requires both launch allowlists; account-free agent checkout
# requires the TLD allowlist but deliberately has no account cohort. Both still
# require their explicit purchase gate plus the shared legal/tax approvals.
{{ $domainPurchases := or .Data.data.domain_purchases_enabled "false" }}
{{ $domainAgentPurchases := or .Data.data.domain_agent_purchases_enabled "false" }}
{{ $domainTlds := or .Data.data.domain_tld_allowlist "[]" }}
{{ $domainAccounts := or .Data.data.domain_account_allowlist "[]" }}
{{ $domainLaunchAllowed := and (gt (len (parseJSON $domainTlds)) 0) (gt (len (parseJSON $domainAccounts)) 0) }}
{{ $domainAgentLaunchAllowed := gt (len (parseJSON $domainTlds)) 0 }}
DOMAIN_ENABLED={{ or .Data.data.domain_enabled "true" }}
DOMAIN_PURCHASES_ENABLED={{ if and (eq (printf "%v" $domainPurchases) "true") $domainLaunchAllowed }}true{{ else }}false{{ end }}
DOMAIN_AGENT_PURCHASES_ENABLED={{ if and (eq (printf "%v" $domainAgentPurchases) "true") $domainAgentLaunchAllowed }}true{{ else }}false{{ end }}
DOMAIN_LEGAL_APPROVED={{ or .Data.data.domain_legal_approved "false" }}
DOMAIN_TAX_APPROVED={{ or .Data.data.domain_tax_approved "false" }}
DOMAIN_TERMS_VERSION={{ or .Data.data.domain_terms_version "2026-07-15" }}
DOMAIN_QUOTE_TTL_SECONDS=900
DOMAIN_CATALOG_SYNC_SECONDS=21600
DOMAIN_CATALOG_MAX_AGE_SECONDS=86400
DOMAIN_RENEWAL_WINDOW_DAYS=60
DOMAIN_RENEWAL_DUE_DAYS=30
DOMAIN_JOB_LOCK_TIMEOUT_SECONDS=900
DOMAIN_MARKUP_PERCENT=0.25
DOMAIN_MARKUP_MIN_USD=3.00
DOMAIN_TLD_ALLOWLIST={{ $domainTlds }}
DOMAIN_ACCOUNT_ALLOWLIST={{ $domainAccounts }}
DOMAIN_MANAGED_NAMESERVERS=["ns1.hyrule.host","ns2.hyrule.host"]
DOMAIN_SOA_MNAME=ns1.hyrule.host
DOMAIN_SOA_RNAME=hostmaster.hyrule.host
DOMAIN_DNS_CONTROL_URL=http://[2a0c:b641:b50:2::10]:8453
DOMAIN_DNS_CONTROL_SECRET={{ .Data.data.domain_dns_control_secret }}
DOMAIN_AUTHCODE_FERNET_KEY={{ .Data.data.domain_authcode_fernet_key }}
DOMAIN_AGENT_ORDER_FERNET_KEY={{ or .Data.data.domain_agent_order_fernet_key "" }}
DOMAIN_OPENPROVIDER_WEBHOOK_SECRET={{ .Data.data.domain_openprovider_webhook_secret }}

# --- Agent Mail (dedicated Stalwart; API-only) ---
# Availability remains false unless these three approvals and every required
# backend/HMAC/Fernet secret are present. Infrastructure launch gates are
# independently enforced in host_vars/agentmail.yml.
MAIL_ENABLED={{ or .Data.data.mail_enabled "false" }}
MAIL_LEGAL_APPROVED={{ or .Data.data.mail_legal_approved "false" }}
MAIL_ABUSE_APPROVED={{ or .Data.data.mail_abuse_approved "false" }}
MAIL_TERMS_VERSION={{ or .Data.data.mail_terms_version "2026-08-04" }}
MAIL_BACKEND_URL={{ or .Data.data.mail_backend_url "https://mx1.agentmail.hyrule.host" }}
MAIL_BACKEND_TOKEN={{ or .Data.data.mail_backend_token "" }}
MAIL_CREDENTIAL_FERNET_KEY={{ or .Data.data.mail_credential_fernet_key "" }}
MAIL_INTERNAL_WEBHOOK_SECRET={{ or .Data.data.mail_internal_webhook_secret "" }}
MAIL_BACKEND_TIMEOUT_SECONDS=15
MAIL_HOSTED_DOMAIN=agentmail.hyrule.host
MAIL_MAIL_HOSTNAME=mx1.agentmail.hyrule.host
MAIL_ACME_PROVIDER_ID={{ or .Data.data.mail_acme_provider_id "" }}
MAIL_STORAGE_QUOTA_BYTES=1073741824
MAIL_ACTIVE_DAYS=30
MAIL_GRACE_DAYS=7
MAIL_RETENTION_DAYS=30
MAIL_QUOTE_TTL_SECONDS=900
MAIL_MAILBOX_SEND_LIMIT_PER_DAY=20
MAIL_MAILBOX_NEW_RECIPIENT_LIMIT_PER_DAY=5
MAIL_GLOBAL_SEND_LIMIT_PER_DAY=100
MAIL_MAX_ACTIVE_MAILBOXES=25
MAIL_MAX_ATTACHMENT_BYTES=26214400

# --- x402 Payments ---
PAYMENT_RECEIVER_ADDRESS={{ .Data.data.payment_wallet }}
PAYMENT_FACILITATOR_URL={{ or .Data.data.payment_facilitator_url "https://facilitator.payai.network" }}
PAYMENT_NETWORK=eip155:8453
PAYMENT_ASSET=USDC
# Coinbase CDP facilitator auth (required when payment_facilitator_url points
# at api.cdp.coinbase.com — unlocks x402 Bazaar discovery indexing).
# The secret is an ES256 PEM with embedded newlines: store it verbatim in
# Vault kv; rendering escapes newlines to literal \n and quotes the value so
# it survives systemd EnvironmentFile parsing (CdpFacilitatorAuthProvider
# converts \n back before signing).
CDP_API_KEY_ID={{ or .Data.data.cdp_api_key_id "" }}
CDP_API_KEY_SECRET="{{ or .Data.data.cdp_api_key_secret "" | replaceAll "\n" "\\n" }}"
# Default false while the Monero wallet-rpc bootstrap is unreliable (invalid
# wallet password + ringdb permission denied; see network-operations#268).
# XMR native payment is unavailable until then; BTC + x402 USDC still work.
# Vault-toggleable: set payment_require_native=true in kv/hyrule-cloud once
# monero-wallet-rpc is healthy.
PAYMENT_REQUIRE_NATIVE={{ or .Data.data.payment_require_native "false" }}
PAYMENT_BTC_XPUB={{ or .Data.data.btc_xpub "" }}
PAYMENT_XMR_VIEWKEY={{ .Data.data.xmr_viewkey }}
PAYMENT_XMR_RPC_URL={{ or .Data.data.xmr_rpc_url "http://127.0.0.1:18088/json_rpc" }}

