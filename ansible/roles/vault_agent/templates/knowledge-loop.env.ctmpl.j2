# /etc/knowledge-loop/knowledge-loop.env
# Rendered by Vault Agent from kv/data/knowledge-loop. Do not edit by hand.
# Secret scope: Knowledge Loop GitHub PR/issue identity, Knowledge Loop
# OpenRouter enrichment key, and optional heartbeat credentials only. Do not add
# fleet SSH, production app, wallet, registrar, or broad Vault credentials here.

{% raw %}{{ with secret "kv/data/knowledge-loop" -}}
{{- if .Data.data.github_app_id }}
KNOWLEDGE_LOOP_GITHUB_AUTH_MODE=app
KNOWLEDGE_LOOP_GITHUB_APP_ID={{ .Data.data.github_app_id }}
KNOWLEDGE_LOOP_GITHUB_APP_INSTALLATION_ID={{ .Data.data.github_app_installation_id }}
KNOWLEDGE_LOOP_GITHUB_APP_PRIVATE_KEY_FILE={% endraw %}{{ knowledge_loop_github_app_private_key_file }}{% raw %}
{{- else if .Data.data.github_token }}
KNOWLEDGE_LOOP_GITHUB_AUTH_MODE=token
GH_TOKEN={{ .Data.data.github_token }}
KNOWLEDGE_LOOP_GITHUB_TOKEN={{ .Data.data.github_token }}
{{- end }}

OPENROUTER_API_KEY={{ or .Data.data.openrouter_api_key "" }}

HYRULE_KNOWLEDGE_LOOP_CREATE_PR={{ or .Data.data.create_pr "1" }}
HYRULE_KNOWLEDGE_LOOP_ENRICH_LIVE={{ or .Data.data.enrich_live "0" }}
HYRULE_KNOWLEDGE_LOOP_MAX_OPENROUTER_CALLS_PER_DAY={{ or .Data.data.max_openrouter_calls_per_day "0" }}
HYRULE_KNOWLEDGE_LOOP_LEARNING_EVENTS={{ or .Data.data.learning_event_paths "" }}

HYRULE_KNOWLEDGE_LOOP_ICINGA_URL={{ or .Data.data.icinga_url "" }}
HYRULE_KNOWLEDGE_LOOP_ICINGA_USER={{ or .Data.data.icinga_user "" }}
HYRULE_KNOWLEDGE_LOOP_ICINGA_PASSWORD={{ or .Data.data.icinga_password "" }}
HYRULE_KNOWLEDGE_LOOP_ICINGA_CHECK={{ or .Data.data.icinga_check "loop!knowledge-loop" }}
{{- end }}{% endraw %}

GIT_ASKPASS={{ knowledge_loop_git_askpass_path }}
GIT_TERMINAL_PROMPT=0
