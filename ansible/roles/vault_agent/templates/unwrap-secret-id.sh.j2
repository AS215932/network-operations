#!/bin/sh
# Managed by ansible/roles/vault_agent. Persistently unwrap a newly staged
# AppRole SecretID without ever returning its plaintext to the controller.
set -eu

wrapped_file={{ vault_agent_wrapped_secret_id_file | quote }}
secret_id_file={{ vault_agent_secret_id_file | quote }}

[ -s "$wrapped_file" ] || exit 0

tmp_file="${secret_id_file}.tmp.$$"
cleanup() {
  rm -f "$tmp_file"
}
trap cleanup EXIT HUP INT TERM
umask 077

wrapped_token="$(tr -d '\r\n' < "$wrapped_file")"
if VAULT_ADDR={{ vault_agent_vault_addr | quote }} \
  VAULT_SKIP_VERIFY={{ 'true' if vault_agent_vault_tls_skip_verify | bool else 'false' }} \
  /usr/bin/vault unwrap -field=secret_id "$wrapped_token" > "$tmp_file"; then
  if [ ! -s "$tmp_file" ]; then
    exit 1
  fi
  chown root:root "$tmp_file"
  chmod 0600 "$tmp_file"
  mv -f "$tmp_file" "$secret_id_file"
  rm -f "$wrapped_file"
  trap - EXIT HUP INT TERM
  exit 0
fi

# A transient unwrap failure must not discard a previously working persistent
# credential. First boot still fails closed when no SecretID exists yet.
[ -s "$secret_id_file" ] && exit 0
exit 1
