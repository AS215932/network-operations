#!/usr/sbin/nft -f
# /etc/nftables.conf — managed by ansible (roles/firewall)
# Host: rtr
# Combines existing IPv4 NAT/forward (preserved verbatim from configs/rtr/nftables.conf)
# with new IPv6 host-level input filter.
# Generated: do not edit by hand.

flush ruleset

# --- IPv4 NAT (DNAT inbound on failover IP, masquerade outbound on WAN) ---
# Original file: configs/rtr/nftables.conf. Preserved here so that
# `ansible --check --diff` shows zero functional change to v4 behaviour
# on first run; only the inet filter table below is new.

define WAN_IP   = {{ rtr_wan_ip }}
define WAN_IF   = {{ rtr_wan_if }}
define DNS_IP   = {{ rtr_dns_v4 }}
define PROXY_IP = {{ rtr_proxy_v4 }}
define VPN_IP   = {{ rtr_vpn_v4 }}

table ip nat {
    chain prerouting {
        type nat hook prerouting priority dstnat; policy accept;

        # DNS → Knot
        ip daddr $WAN_IP tcp dport 53 dnat to $DNS_IP
        ip daddr $WAN_IP udp dport 53 dnat to $DNS_IP

        # HTTP/HTTPS → Caddy
        ip daddr $WAN_IP tcp dport { 80, 443 } dnat to $PROXY_IP

        # WireGuard VPN → vpn VM
        ip daddr $WAN_IP udp dport 51820 dnat to $VPN_IP
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;

        # Masquerade on WAN — preserves source IPs through DNAT (no masq on enX2),
        # and allows infra VMs to reach IPv4 internet (outgoing NAT).
        oifname $WAN_IF masquerade
    }
}

table ip filter {
    chain forward {
        type filter hook forward priority filter; policy accept;

        # Allow return traffic before customer isolation drops.
        ct state established,related accept
        ct state invalid drop

        # Customer VM isolation: packets from the customer bridge must not
        # reach infrastructure/mgmt ranges.  Match destination prefixes first
        # so enforcement does not depend solely on VRF slave oifname exposure.
        iifname enX3 ip daddr { {{ customer_isolation_block_v4 | join(', ') }} } counter drop comment "customer→infra/mgmt v4 isolation"
        iifname enX3 oifname { enX2, enX0 } counter drop comment "customer→infra/mgmt bridge isolation"

        # Allow DNAT'd traffic to infra VMs
        ip daddr $DNS_IP tcp dport 53 accept
        ip daddr $DNS_IP udp dport 53 accept
        ip daddr $PROXY_IP tcp dport { 80, 443 } accept
        ip daddr $VPN_IP udp dport 51820 accept
    }
}

# --- IPv6 host filter — new in this rollout ---
table inet filter {
    chain input {
        type filter hook input priority filter; policy {{ firewall_input_policy }};

{% include 'partials/_input_base.j2' %}

        # Per-host service allowances.
{% include 'partials/_extra_rules.j2' %}
{% include 'partials/_netconf_endpoint_nft.j2' %}

{% if firewall_extra_raw_nft %}
        # --- raw escape hatch ---
{{ firewall_extra_raw_nft | indent(8, True) }}
{% endif %}

        # End of input — log what would have been dropped.
{% if firewall_log_only or firewall_input_policy == 'accept' %}
        limit rate 10/second counter log prefix "fw-would-drop " accept
{% else %}
        limit rate 10/second counter log prefix "fw-drop "
{% endif %}
    }

    chain forward {
        type filter hook forward priority filter; policy accept;

        # Allow return traffic before customer isolation drops.
        ct state established,related accept
        ct state invalid drop

        # Customer VM isolation for IPv6.  The source/destination-prefix rule is
        # VRF-safe (does not rely on oifname); the bridge rule catches spoofed
        # customer packets seen with the physical vm-bridge ingress device.
        ip6 saddr {{ customer_subnet }} ip6 daddr { {{ customer_isolation_block_v6 | join(', ') }} } counter drop comment "customer→infra/router v6 isolation"
        iifname enX3 ip6 daddr { {{ customer_isolation_block_v6 | join(', ') }} } counter drop comment "customer→infra/router v6 bridge isolation"
        iifname enX3 oifname { enX2, enX0 } counter drop comment "customer→infra/mgmt bridge isolation"
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}
