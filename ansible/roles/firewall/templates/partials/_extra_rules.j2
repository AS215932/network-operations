{# Render firewall_extra_rules into nftables syntax.
   Each rule dict supports:
     proto:   tcp | udp | tcp+udp | icmp | icmp6 | ospf
     dport:   int | "80-100" | [80, 443]                       (omit for non-port protos)
     src:     "any" | "addr/cidr" | [list of addrs]
     iifname: optional interface restriction
     family:  ip6 (default) | ip | both
     comment: required, becomes the rule comment
#}
{% macro render_src(src, family) -%}
{%- if src == 'any' -%}
{# no saddr clause — match anything #}
{%- elif src is iterable and src is not string -%}
{{ family }} saddr { {{ src | join(', ') }} }
{%- else -%}
{{ family }} saddr {{ src }}
{%- endif -%}
{%- endmacro -%}
{% macro render_dport(dport) -%}
{%- if dport is iterable and dport is not string -%}
dport { {{ dport | join(', ') }} }
{%- else -%}
dport {{ dport }}
{%- endif -%}
{%- endmacro -%}
{% for r in firewall_extra_rules %}
{% set fams = ['ip6'] if (r.family | default('ip6')) == 'ip6' else (['ip'] if r.family == 'ip' else ['ip6', 'ip']) %}
{% set protos = ['tcp', 'udp'] if r.proto == 'tcp+udp' else [r.proto] %}
{% for fam in fams %}
{% for proto in protos %}
        {% if r.iifname is defined %}iifname {{ r.iifname }} {% endif %}{{ render_src(r.src, fam) }} {% if proto in ['tcp', 'udp'] %}{{ proto }} {{ render_dport(r.dport) }} {% endif %}counter accept comment "{{ r.comment }}"
{% endfor %}
{% endfor %}
{% endfor %}
