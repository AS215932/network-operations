# /etc/dovecot/local.conf — managed by ansible/roles/mail_openbsd

protocols = imap lmtp sieve
listen = *

ssl = required
ssl_cert = </etc/ssl/{{ mail_hostname }}.fullchain.pem
ssl_key = </etc/ssl/private/{{ mail_hostname }}.key

mail_location = maildir:~/Maildir

namespace inbox {
  inbox = yes
}

service imap-login {
  inet_listener imap {
    port = 0
  }
  inet_listener imaps {
    port = 993
    ssl = yes
  }
}

service pop3-login {
  inet_listener pop3 {
    port = 0
  }
  inet_listener pop3s {
    port = 0
  }
}

service lmtp {
  unix_listener /var/dovecot/lmtp {
    mode = 0666
  }
}

service managesieve-login {
  inet_listener sieve {
    port = 4190
  }
}

protocol lmtp {
  mail_plugins = $mail_plugins sieve
}

protocol lda {
  mail_plugins = $mail_plugins sieve
}
