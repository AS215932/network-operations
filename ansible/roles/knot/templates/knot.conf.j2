# /etc/knot/knot.conf — managed by ansible/roles/knot.
# Host:  {{ inventory_hostname }}
# Role:  {{ knot_role }}
#
# Do not edit manually — changes will be overwritten on next deploy.

server:
  listen: [ ::@53, 0.0.0.0@53 ]
  rundir: "/run/knot"
  user: knot:knot

log:
  - target: syslog
    any: info

database:
  storage: "/var/lib/knot"

# TSIG key shared between primary (dns) and all secondaries. Name MUST be
# "{{ knot_tsig_key_name }}" — hardcoded in hyrule_cloud/providers/dns.py.
key:
  - id: {{ knot_tsig_key_name }}
    algorithm: hmac-sha256
    secret: "{{ knot_tsig_secret }}"

{% if knot_role == "primary" %}
# --- Primary: notifies + serves AXFR to secondaries -----------------------
{% if knot_secondaries | length > 0 %}
remote:
{% for s in knot_secondaries %}
  - id: {{ s.name }}
    address: [ {{ s.address_v6 }}, {{ s.address_v4 }} ]
    key: {{ knot_tsig_key_name }}
{% endfor %}
{% endif %}

acl:
  # RFC 2136 dynamic updates from authorized clients (TSIG-authed).
  - id: api-update
    address: {{ peers.api.ipv6 }}
    key: {{ knot_tsig_key_name }}
    action: update

  - id: caddy-update
    address: {{ peers.proxy.ipv6 }}
    key: {{ knot_tsig_key_name }}
    action: update

  - id: irc-update
    address: {{ peers.irc.ipv6 }}
    key: {{ knot_tsig_key_name }}
    action: update

{% for s in knot_secondaries %}
  - id: {{ s.name }}-xfr
    address: [ {{ s.address_v6 }}, {{ s.address_v4 }} ]
    key: {{ knot_tsig_key_name }}
    action: transfer
{% endfor %}

  # AXFR from the ops home network (no TSIG — IP-based for ad-hoc dig +axfr).
  - id: home-xfr
    address: [ {{ ops_prefix_v4 }}, {{ ops_prefix_v6 }} ]
    action: transfer

policy:
  - id: {{ knot_customer_dnssec_policy }}
    algorithm: ecdsap256sha256
    ksk-shared: off
    zsk-lifetime: 60d
    zone-max-ttl: 1d

template:
  - id: default
    storage: "/var/lib/knot/zones"
    file: "%s.zone"
    journal-content: all
    zonefile-load: difference-no-serial
{% if knot_secondaries | length > 0 %}
    notify: [ {{ knot_secondaries | map(attribute='name') | join(', ') }} ]
{% endif %}

{% if knot_customer_catalog_enabled %}
  - id: {{ knot_customer_member_template }}
    storage: "{{ knot_customer_zones_dir }}"
    file: "%s.zone"
    journal-content: all
    zonefile-load: difference-no-serial
    dnssec-signing: on
    dnssec-policy: {{ knot_customer_dnssec_policy }}
    catalog-role: member
    catalog-zone: {{ knot_customer_catalog_zone }}
    acl: [ home-xfr{% for s in knot_secondaries %}, {{ s.name }}-xfr{% endfor %} ]
{% if knot_secondaries | length > 0 %}
    notify: [ {{ knot_secondaries | map(attribute='name') | join(', ') }} ]
{% endif %}

  - id: customer-catalog-primary
    journal-content: all
    acl: [ home-xfr{% for s in knot_secondaries %}, {{ s.name }}-xfr{% endfor %} ]
{% if knot_secondaries | length > 0 %}
    notify: [ {{ knot_secondaries | map(attribute='name') | join(', ') }} ]
{% endif %}
{% endif %}

zone:
{% for z in knot_zones %}
  - domain: {{ z.name }}
    acl: [ api-update, caddy-update, irc-update, home-xfr{% for s in knot_secondaries %}, {{ s.name }}-xfr{% endfor %} ]
    template: default
{% endfor %}
{% if knot_customer_catalog_enabled %}
  - domain: {{ knot_customer_catalog_zone }}
    template: customer-catalog-primary
    catalog-role: generate
{% endif %}

{% if knot_customer_catalog_enabled %}
# Atomically regenerated by the internal control service. Keep this after the
# customer-member template and catalog zone declarations because Knot resolves
# section references in declaration order.
include: "{{ knot_customer_zones_config }}"
{% endif %}

{% else %}
# --- Secondary: pulls AXFR from primary -----------------------------------
remote:
  - id: ns1
    address: [ {{ knot_primary_v6 }}, {{ knot_primary_v4 }} ]
    key: {{ knot_tsig_key_name }}

acl:
  - id: ns1-notify
    address: [ {{ knot_primary_v6 }}, {{ knot_primary_v4 }} ]
    key: {{ knot_tsig_key_name }}
    action: notify

template:
  - id: default
    storage: "/var/lib/knot/zones"
    file: "%s.zone"
    master: [ ns1 ]
    acl: [ ns1-notify ]

{% if knot_customer_catalog_enabled %}
  - id: {{ knot_customer_secondary_template }}
    storage: "{{ knot_customer_zones_dir }}"
    file: "%s.zone"
    master: [ ns1 ]
    acl: [ ns1-notify ]
    journal-content: all
{% endif %}

zone:
{% for z in knot_zones %}
  - domain: {{ z.name }}
{% endfor %}
{% if knot_customer_catalog_enabled %}
  - domain: {{ knot_customer_catalog_zone }}
    master: [ ns1 ]
    acl: [ ns1-notify ]
    catalog-role: interpret
    catalog-template: {{ knot_customer_secondary_template }}
{% endif %}

{% endif %}
