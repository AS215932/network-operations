# Deploy path: {{ knowledge_api_env_file }}
# Non-secret Knowledge API config, rendered by ansible/roles/knowledge_api.
# The API is read-only and needs no secret (collector GET /v1/insights is open).

HYRULE_KNOWLEDGE_CONFIG={{ knowledge_api_config }}
HYRULE_KNOWLEDGE_API_HOST={{ knowledge_api_bind }}
HYRULE_KNOWLEDGE_API_PORT={{ knowledge_api_port }}
HYRULE_KNOWLEDGE_COLLECTOR_URL={{ knowledge_api_collector_url }}
