; /var/lib/knot/zones/servify.network.zone
; Deploy to: dns VM (2a0c:b641:b50:2::10)
;
; Variables:
;   {{ pub_ip4 }}  — OVH public IPv4 (for dual-stack external access)

$ORIGIN servify.network.
$TTL 3600

@       IN  SOA   ns1.servify.network. admin.servify.network. (
                  2026040101 ; serial (YYYYMMDDNN)
                  3600       ; refresh (1h)
                  900        ; retry (15m)
                  604800     ; expire (7d)
                  300 )      ; negative TTL (5m)

; Nameservers
@       IN  NS    ns1.servify.network.
@       IN  NS    ns2.servify.network.

; NS glue records — dual-stack for maximum reachability
ns1     IN  A     {{ pub_ip4 }}
ns1     IN  AAAA  2a0c:b641:b50:2::10
ns2     IN  A     {{ pub_ip4 }}
ns2     IN  AAAA  2a0c:b641:b50:2::10

; Web frontend — dual-stack (IPv4 via fw redirect, IPv6 direct to proxy)
@       IN  A     {{ pub_ip4 }}
@       IN  AAAA  2a0c:b641:b50:2::40

; API — dual-stack
api     IN  A     {{ pub_ip4 }}
api     IN  AAAA  2a0c:b641:b50:2::40

; Delegate deploy.servify.network to our own nameservers
; Dynamic AAAA records managed via RFC 2136 from the API
deploy  IN  NS    ns1.servify.network.
deploy  IN  NS    ns2.servify.network.
