# /opt/hyrule-cloud/.env — Production configuration
# Deploy to: api VM (2a0c:b641:b50:2::20)
#
# All values must be filled before starting the service.
# Generate TSIG key with: scripts/generate-tsig-key.sh
# Get XO token from: Xen Orchestra -> Settings -> Tokens

# --- XCP-NG (XAPI direct, for simple queries) ---
XCPNG_HOST=https://[2a0c:b641:b50::1]:443
XCPNG_USERNAME=root
XCPNG_PASSWORD={{ xcpng_password }}
XCPNG_VERIFY_SSL=false

# --- Xen Orchestra (WebSocket JSON-RPC, for VM lifecycle) ---
XCPNG_XO_URL=wss://[2a0c:b641:b50::10]/api/
XCPNG_XO_TOKEN={{ xo_token }}

# --- Storage & Network ---
XCPNG_DEFAULT_SR_UUID={{ sr_uuid }}
XCPNG_DEFAULT_NETWORK_UUID={{ vm_network_uuid }}

# --- Templates (JSON dict: {"os-name": "template-uuid"}) ---
XCPNG_TEMPLATES={{ xcpng_templates | default('{"debian-13": ""}') }}

# --- Openprovider ---
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME={{ openprovider_username }}
OPENPROVIDER_PASSWORD={{ openprovider_password }}
OPENPROVIDER_OWNER_HANDLE={{ openprovider_owner_handle }}
OPENPROVIDER_ADMIN_HANDLE={{ openprovider_admin_handle }}
OPENPROVIDER_TECH_HANDLE={{ openprovider_tech_handle }}
OPENPROVIDER_BILLING_HANDLE={{ openprovider_billing_handle }}
OPENPROVIDER_NAMESERVERS=["ns1.servify.network","ns2.servify.network"]

# --- x402 Payments ---
PAYMENT_RECEIVER_ADDRESS={{ payment_wallet }}
PAYMENT_FACILITATOR_URL=https://x402.org/facilitator
PAYMENT_NETWORK=eip155:8453
PAYMENT_ASSET=USDC

# Pricing (USD per day)
PAYMENT_PRICE_VM_XS=0.05
PAYMENT_PRICE_VM_SM=0.10
PAYMENT_PRICE_VM_MD=0.20
PAYMENT_PRICE_VM_LG=0.40
PAYMENT_PRICE_VPN=0.02
PAYMENT_PRICE_DOMAIN_MARKUP=1.00

# Dev bypass — set a random secret for staging, leave EMPTY for production
PAYMENT_DEV_BYPASS_SECRET={{ dev_bypass_secret | default('') }}

# --- Hyrule ---
HYRULE_DEPLOY_DOMAIN=deploy.servify.network

# DNS (RFC 2136 dynamic updates to Knot DNS)
HYRULE_DNS_SERVER=2a0c:b641:b50:2::10
HYRULE_DNS_TSIG_KEY={{ tsig_secret }}
HYRULE_DNS_TSIG_ALGO=hmac-sha256

# VM lifecycle
HYRULE_VM_GRACE_PERIOD_HOURS=48
HYRULE_MAX_DURATION_DAYS=365
HYRULE_MAX_PORTS=10
HYRULE_BLOCKED_PORTS=[25,465,587]

# Database (PostgreSQL on localhost via IPv6 loopback)
HYRULE_DATABASE_URL=postgresql+asyncpg://hyrule:{{ db_password }}@localhost/hyrule
