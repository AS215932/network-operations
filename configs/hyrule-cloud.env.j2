# /opt/hyrule-cloud/.env — Production configuration
# Deploy to: api VM (2a0c:b641:b50:2::20)
#
# All values must be filled before starting the service.
# Generate TSIG key with: scripts/generate-tsig-key.sh
# Get XO token from: Xen Orchestra -> Settings -> Tokens

# --- Xen Orchestra (WebSocket JSON-RPC) ---
# All XCP-NG operations go through XO. XO proxies XAPI calls internally.
# dom0 stays underlay-only; XO has mgmt-side access to XAPI at 10.0.0.1.
XCPNG_XO_URL=wss://xo.servify.network/api/
XCPNG_XO_TOKEN={{ xo_token }}
XCPNG_XO_VERIFY_SSL=true

# --- Storage & Network ---
XCPNG_DEFAULT_SR_UUID={{ sr_uuid }}
XCPNG_DEFAULT_NETWORK_UUID={{ vm_network_uuid }}
# Admission control: 2:1 CPU, no RAM overcommit, preserve recovery headroom.
XCPNG_VCPU_OVERCOMMIT_RATIO=2.0
XCPNG_MEMORY_HEADROOM_MB=2048
XCPNG_STORAGE_HEADROOM_GB=20

# --- Templates (JSON dict: {"os-name": "template-uuid"}) ---
XCPNG_TEMPLATES={{ xcpng_templates | default('{"debian-13": ""}') }}

# --- OpenBSD offline root resize builder ---
# Required for OpenBSD templates because OpenBSD growfs cannot grow mounted /.
XCPNG_OPENBSD_BUILDER_VM_UUID={{ xcpng_openbsd_builder_vm_uuid | default('') }}
XCPNG_OPENBSD_BUILDER_SSH_HOST={{ xcpng_openbsd_builder_ssh_host | default('') }}
XCPNG_OPENBSD_BUILDER_SSH_USER={{ xcpng_openbsd_builder_ssh_user | default('svag') }}
XCPNG_OPENBSD_BUILDER_SSH_KEY_PATH={{ xcpng_openbsd_builder_ssh_key_path | default('/run/secrets/openbsd_builder_ssh_key') }}
XCPNG_OPENBSD_BUILDER_DISK_DEVICE={{ xcpng_openbsd_builder_disk_device | default('sd1') }}
XCPNG_OPENBSD_BUILDER_ATTACH_POSITION={{ xcpng_openbsd_builder_attach_position | default('1') }}

# --- Openprovider ---
OPENPROVIDER_API_URL=https://api.openprovider.eu/v1beta
OPENPROVIDER_USERNAME={{ openprovider_username }}
OPENPROVIDER_PASSWORD={{ openprovider_password }}
OPENPROVIDER_OWNER_HANDLE={{ openprovider_owner_handle }}
OPENPROVIDER_ADMIN_HANDLE={{ openprovider_admin_handle }}
OPENPROVIDER_TECH_HANDLE={{ openprovider_tech_handle }}
OPENPROVIDER_BILLING_HANDLE={{ openprovider_billing_handle }}
OPENPROVIDER_NAMESERVERS=["ns1.hyrule.host","ns2.hyrule.host"]

# --- Managed customer domains ---
DOMAIN_ENABLED={{ domain_enabled | default('true') }}
DOMAIN_PURCHASES_ENABLED={{ domain_purchases_enabled | default('false') }}
DOMAIN_LEGAL_APPROVED={{ domain_legal_approved | default('false') }}
DOMAIN_TAX_APPROVED={{ domain_tax_approved | default('false') }}
DOMAIN_TERMS_VERSION={{ domain_terms_version | default('2026-07-15') }}
DOMAIN_QUOTE_TTL_SECONDS=900
DOMAIN_CATALOG_SYNC_SECONDS=21600
DOMAIN_CATALOG_MAX_AGE_SECONDS=86400
DOMAIN_RENEWAL_WINDOW_DAYS=60
DOMAIN_RENEWAL_DUE_DAYS=30
DOMAIN_JOB_LOCK_TIMEOUT_SECONDS=900
DOMAIN_MARKUP_PERCENT=0.25
DOMAIN_MARKUP_MIN_USD=3.00
DOMAIN_TLD_ALLOWLIST={{ domain_tld_allowlist | default('[]') }}
DOMAIN_ACCOUNT_ALLOWLIST={{ domain_account_allowlist | default('[]') }}
DOMAIN_MANAGED_NAMESERVERS=["ns1.hyrule.host","ns2.hyrule.host"]
DOMAIN_SOA_MNAME=ns1.hyrule.host
DOMAIN_SOA_RNAME=hostmaster.hyrule.host
DOMAIN_DNS_CONTROL_URL=http://[2a0c:b641:b50:2::10]:8453
DOMAIN_DNS_CONTROL_SECRET={{ domain_dns_control_secret }}
DOMAIN_AUTHCODE_FERNET_KEY={{ domain_authcode_fernet_key }}
DOMAIN_OPENPROVIDER_WEBHOOK_SECRET={{ domain_openprovider_webhook_secret }}

# --- x402 Payments ---
PAYMENT_RECEIVER_ADDRESS={{ payment_wallet }}
PAYMENT_FACILITATOR_URL={{ payment_facilitator_url | default('https://facilitator.payai.network') }}
PAYMENT_NETWORK=eip155:8453
PAYMENT_ASSET=USDC

# Pricing (USD per day)
PAYMENT_PRICE_VM_XS=0.20
PAYMENT_PRICE_VM_SM=0.40
PAYMENT_PRICE_VM_MD=0.60
PAYMENT_PRICE_VM_LG=0.80
PAYMENT_PRICE_VM_ADDON_VCPU=0.10
PAYMENT_PRICE_VM_ADDON_RAM_GB=0.15
PAYMENT_PRICE_VM_ADDON_DISK_10GB=0.05
PAYMENT_PRICE_VPN=0.02
PAYMENT_PRICE_PROXY_DIRECT=0.01
PAYMENT_PRICE_PROXY_TOR=0.05
PAYMENT_PRICE_PROXY_I2P=0.05
PAYMENT_PRICE_PROXY_YGGDRASIL=0.03
PAYMENT_PRICE_BGP_LOOKUP={{ payment_price_bgp_lookup | default('0.005') }}
PAYMENT_PRICE_BGP_ROUTER_QUERY={{ payment_price_bgp_router_query | default('0.01') }}
PAYMENT_PRICE_BGPSTREAM_HOUR={{ payment_price_bgpstream_hour | default('0.05') }}
PAYMENT_PRICE_BGPSTREAM_RIB={{ payment_price_bgpstream_rib | default('0.10') }}
PAYMENT_PRICE_BGP_ROUTER_TABLE={{ payment_price_bgp_router_table | default('0.10') }}
PAYMENT_PRICE_BGP_ROUTER_TABLE_ALL={{ payment_price_bgp_router_table_all | default('0.25') }}
PAYMENT_PRICE_IP_LOOKUP={{ payment_price_ip_lookup | default('0.003') }}
PAYMENT_PRICE_IP_QUALITY={{ payment_price_ip_quality | default('0.02') }}
PAYMENT_PRICE_DNS_LOOKUP={{ payment_price_dns_lookup | default('0.001') }}
PAYMENT_PRICE_RDAP_LOOKUP={{ payment_price_rdap_lookup | default('0.003') }}
PAYMENT_PRICE_WHOIS_LOOKUP={{ payment_price_whois_lookup | default('0.005') }}
PAYMENT_PRICE_MX_CHECK={{ payment_price_mx_check | default('0.005') }}
PAYMENT_PRICE_MX_REPORT={{ payment_price_mx_report | default('0.03') }}
PAYMENT_PRICE_WEB_CHECK={{ payment_price_web_check | default('0.005') }}
PAYMENT_PRICE_WEB_REPORT={{ payment_price_web_report | default('0.03') }}
PAYMENT_PRICE_WEB_TLS_DEEP={{ payment_price_web_tls_deep | default('0.10') }}
PAYMENT_PRICE_PATH_PROBE={{ payment_price_path_probe | default('0.005') }}
PAYMENT_PRICE_PATH_REPORT={{ payment_price_path_report | default('0.05') }}
PAYMENT_PRICE_PORT_CHECK={{ payment_price_port_check | default('0.003') }}
PAYMENT_PRICE_NAT_LOOKUP={{ payment_price_nat_lookup | default('0.003') }}
PAYMENT_PRICE_NAT_PORT_FORWARD_CHECK={{ payment_price_nat_port_forward_check | default('0.005') }}
PAYMENT_PRICE_THREAT_LOOKUP={{ payment_price_threat_lookup | default('0.01') }}
PAYMENT_PRICE_VOIP_CHECK={{ payment_price_voip_check | default('0.01') }}
PAYMENT_PRICE_VOIP_NUMBER_LOOKUP={{ payment_price_voip_number_lookup | default('0.05') }}
PAYMENT_PRICE_VOIP_REPORT={{ payment_price_voip_report | default('0.08') }}
PAYMENT_PRICE_SPEEDTEST={{ payment_price_speedtest | default('0.10') }}
PAYMENT_PRICE_MAIL_AGENT_BASIC_DAY={{ payment_price_mail_agent_basic_day | default('0.05') }}
PAYMENT_PRICE_MAIL_STORAGE_GB_DAY={{ payment_price_mail_storage_gb_day | default('0.01') }}
PAYMENT_PRICE_MAIL_OUTBOUND_MESSAGE={{ payment_price_mail_outbound_message | default('0.001') }}

# Dev bypass — set a random secret for staging, leave EMPTY for production
PAYMENT_DEV_BYPASS_SECRET={{ dev_bypass_secret | default('') }}

# --- Licensed IP quality (fail-closed dark launch) ---
IP_QUALITY_ENABLED={{ ip_quality_enabled | default('false') }}
IP_QUALITY_MAXMIND_ACCOUNT_ID={{ ip_quality_maxmind_account_id | default('') }}
IP_QUALITY_MAXMIND_LICENSE_KEY={{ ip_quality_maxmind_license_key | default('') }}
IP_QUALITY_MAXMIND_RESALE_APPROVED={{ ip_quality_maxmind_resale_approved | default('false') }}
IP_QUALITY_MAXMIND_UNIT_COST_USD={{ ip_quality_maxmind_unit_cost_usd | default('0') }}
IP_QUALITY_IPQS_API_KEY={{ ip_quality_ipqs_api_key | default('') }}
IP_QUALITY_IPQS_RESALE_APPROVED={{ ip_quality_ipqs_resale_approved | default('false') }}
IP_QUALITY_IPQS_UNIT_COST_USD={{ ip_quality_ipqs_unit_cost_usd | default('0') }}
IP_QUALITY_PROVIDER_TIMEOUT_SECONDS=5
IP_QUALITY_CACHE_RIGHTS_APPROVED={{ ip_quality_cache_rights_approved | default('false') }}
IP_QUALITY_CACHE_TTL_SECONDS={{ ip_quality_cache_ttl_seconds | default('0') }}
HYRULE_IP_QUALITY_TOOL_ENABLED={{ ip_quality_tool_enabled | default('false') }}

# --- Agent-first network observations (fail-closed dark launch) ---
IP_CHECK_ENABLED={{ ip_check_enabled | default('false') }}
IP_CHECK_SESSION_TTL_SECONDS=900
IP_CHECK_API_BASE_URL=https://cloud.hyrule.host
IP_CHECK_V4_PROBE_BASE_URL=https://v4.check.hyrule.host
IP_CHECK_V6_PROBE_BASE_URL=https://v6.check.hyrule.host
IP_CHECK_DNS_ZONE=dns.check.hyrule.host
IP_CHECK_STUN_URLS=["stun:stun.hyrule.host:3478"]
IP_CHECK_DNS_OBSERVER_SECRET={{ ip_check_dns_observer_secret }}
IP_CHECK_DNS_OBSERVER_CLOCK_SKEW_SECONDS=60

# --- Hyrule ---
HYRULE_DEPLOY_DOMAIN=deploy.hyrule.host
HYRULE_NETWORK_PROXY_URL=http://[2a0c:b641:b50:2::e0]:8450
HYRULE_NETWORK_PROXY_TOKEN={{ network_proxy_token | default('') }}
HYRULE_NETWORK_PROXY_HEALTH_TTL_SECONDS=15
HYRULE_BGP_DATA_ENABLED=true
HYRULE_BGP_DATA_DIR=/var/lib/hyrule-cloud/bgp
HYRULE_BGP_INGEST_TOKEN={{ bgp_ingest_token | default('') }}
HYRULE_CUSTOMER_IPV6_SUPERNET={{ hyrule_customer_ipv6_supernet | default('2a0c:b641:b51::/48') }}
HYRULE_CUSTOMER_IPV6_GATEWAY={{ hyrule_customer_ipv6_gateway | default('2a0c:b641:b51::1') }}
HYRULE_CUSTOMER_IPV6_DNS={{ hyrule_customer_ipv6_dns | default('2a0c:b641:b51::1') }}

# DNS (RFC 2136 dynamic updates to Knot DNS)
HYRULE_DNS_SERVER=2a0c:b641:b50:2::10
HYRULE_DNS_TSIG_KEY={{ tsig_secret }}
HYRULE_DNS_TSIG_ALGO=hmac-sha256

# VM lifecycle
HCP_LAUNCH_PROOF_REAL_XCPNG={{ hcp_launch_proof_real_xcpng | default('1') }}
HYRULE_VM_GRACE_PERIOD_HOURS=48
HYRULE_MAX_DURATION_DAYS=365
HYRULE_MAX_PORTS=10
HYRULE_BLOCKED_PORTS=[25,465,587]

# Database (PostgreSQL on localhost via IPv6 loopback)
HYRULE_DATABASE_URL=postgresql+asyncpg://hyrule:{{ db_password }}@localhost/hyrule?ssl=disable
