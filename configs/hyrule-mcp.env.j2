# Reference template for hyrule-mcp env vars.
#
# NOT directly deployed — hyrule-mcp runs as a stdio child of noc-agent and
# inherits its parent's environment (rendered into /opt/noc-agent/.env from
# configs/noc-agent.env.j2). Kept here as documentation of which env vars the
# MCP consumes if you ever want to invoke it standalone (e.g., for ad-hoc
# debugging via Claude Code over SSH).

PROMETHEUS_URL=http://[{{ peers.mon.ipv6 }}]:9090
HYRULE_MCP_HOSTS_CONFIG=/etc/hyrule-mcp/hosts.yml

# Icinga2 REST API on mon. Replaces the previous hardcoded root:icinga literal.
ICINGA_API_USER={{ icinga_api_user }}
ICINGA_API_PASSWORD={{ icinga_api_password }}

# Shadow mode — when 0, os_systemd_restart and icinga_acknowledge_alert are
# not registered as MCP tools. Flip to 1 only after observing the agent's
# behaviour for a few weeks.
HYRULE_MCP_ENABLE_ACTIONS=0
