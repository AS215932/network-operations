# /etc/systemd/network/20-wg0.netdev — WireGuard tunnel to cr1.nl1
[NetDev]
Name=wg0
Kind=wireguard

[WireGuard]
PrivateKeyFile=/etc/wireguard/private.key
ListenPort=1337

[WireGuardPeer]
PublicKey=yx1cxAkZqG065H+ali8OSaK7j2xobxlCObs1ymGd4zc=
Endpoint=[2a0c:b640:8:69::1]:1340
AllowedIPs=::/0
PersistentKeepalive=30
RouteTable=off
