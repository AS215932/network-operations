# /etc/knot/knot.conf — Hyrule Cloud authoritative DNS (Knot DNS)
# Deploy to: dns VM (2a0c:b641:b50:2::10)
#
# Variables to fill:
#   {{ tsig_secret }}  — Base64 TSIG key (generate with scripts/generate-tsig-key.sh)

server:
    listen: [ ::@53 ]
    rundir: "/run/knot"
    user: knot:knot

log:
  - target: syslog
    any: info

database:
    storage: "/var/lib/knot"

# TSIG key for RFC 2136 dynamic updates from the API server.
# Key name MUST be "hyrule-dns" — hardcoded in hyrule_cloud/providers/dns.py
key:
  - id: hyrule-dns
    algorithm: hmac-sha256
    secret: "{{ tsig_secret }}"

acl:
  - id: api-update
    address: 2a0c:b641:b50:2::20
    key: hyrule-dns
    action: update

  - id: caddy-update
    address: 2a0c:b641:b50:2::40
    key: hyrule-dns
    action: update

  - id: transfer
    action: transfer

template:
  - id: default
    storage: "/var/lib/knot/zones"
    file: "%s.zone"
    journal-content: all

zone:
  - domain: servify.network
    acl: [ api-update, caddy-update, transfer ]
    template: default

  - domain: deploy.servify.network
    acl: [ api-update, transfer ]
    template: default

  - domain: as215932.net
    acl: [ transfer ]
    template: default

  # Reverse DNS (PTR) for 2a0c:b641:b50::/48 infrastructure
  - domain: 0.5.b.1.4.6.b.c.0.a.2.ip6.arpa
    acl: [ transfer ]
    template: default
