# /etc/knot/knot.conf — Hyrule Cloud authoritative DNS (Knot DNS)
# Deploy to: dns VM (2a0c:b641:b50:2::10)
#
# Variables to fill:
#   {{ tsig_secret }}  — Base64 TSIG key (generate with scripts/generate-tsig-key.sh)

server:
  listen: [ ::@53, 0.0.0.0@53 ]
  rundir: "/run/knot"
  user: knot:knot

log:
  - target: syslog
    any: info

database:
  storage: "/var/lib/knot"

# TSIG key for RFC 2136 dynamic updates from the API server.
# Key name MUST be "hyrule-dns" — hardcoded in hyrule_cloud/providers/dns.py
key:
  - id: hyrule-dns
    algorithm: hmac-sha256
    secret: "{{ tsig_secret }}"

# Openprovider secondary nameservers — NOTIFY targets + AXFR sources
remote:
  - id: openprovider
    address: [ 35.157.8.190, 18.203.73.190, 185.27.175.218, 2a00:f10:121:400:4be:60ff:fe00:526, 2a05:d014:f80:6e00:c937:174c:45eb:a5f7 ]

acl:
  - id: api-update
    address: 2a0c:b641:b50:2::20
    key: hyrule-dns
    action: update

  - id: caddy-update
    address: 2a0c:b641:b50:2::40
    key: hyrule-dns
    action: update

  - id: openprovider-xfr
    address: [ 35.157.8.190, 18.203.73.190, 185.27.175.218, 2a00:f10:121:400:4be:60ff:fe00:526, 2a05:d014:f80:6e00:c937:174c:45eb:a5f7 ]
    action: transfer

template:
  - id: default
    storage: "/var/lib/knot/zones"
    file: "%s.zone"
    journal-content: all
    notify: [ openprovider ]

zone:
  - domain: servify.network
    acl: [ api-update, caddy-update, openprovider-xfr ]
    template: default

  - domain: deploy.servify.network
    acl: [ api-update, openprovider-xfr ]
    template: default

  - domain: as215932.net
    acl: [ openprovider-xfr ]
    template: default

  - domain: 0.5.b.1.4.6.b.c.0.a.2.ip6.arpa
    acl: [ openprovider-xfr ]
    template: default
