; /var/lib/knot/zones/as215932.net.zone
; Deploy to: dns VM (2a0c:b641:b50:2::10)
;
; Forward zone for AS215932 infrastructure PTR naming.
; PTR records in the ip6.arpa zone point here (e.g. fw.as215932.net).

$ORIGIN as215932.net.
$TTL 3600

@       IN  SOA   ns1.servify.network. admin.servify.network. (
                  2026071101 ; serial (YYYYMMDDNN)
                  3600       ; refresh (1h)
                  900        ; retry (15m)
                  604800     ; expire (7d)
                  300 )      ; negative TTL (5m)

; Out-of-bailiwick NS — resolvers chase glue via the parent (servify.network).
@       IN  NS    ns1.servify.network.
@       IN  NS    ns2.servify.network.

; --- Mail for AS215932 operational role accounts ---
@       IN  MX    10 mail.as215932.net.
@       IN  TXT   "v=spf1 ip4:51.91.236.215 ip6:2a0c:b641:b50:2::90 -all"
_dmarc  IN  TXT   "v=DMARC1; p=none; rua=mailto:noc@as215932.net; adkim=s; aspf=s"
; DKIM selector for Rspamd signing on mail.as215932.net.
dkim._domainkey IN TXT ( "v=DKIM1; k=rsa; p=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAxF/V0NkAuLkXFZ6WVPqTrdi1na7DZKHXFl605qBrhhgiFM6oR65kPivhwKcP7S+8PsbxAIzZb2irl1RUZqeTrYigsetugKyg7ONX1o5C9+JEO+BuY4ug6Lg9LRMy00q+DNKV7HxD"
                  "3Cp8mwEcJNiMXHzGhEGzry5O93mzkT/vFSxytwrsLychXpt6OKQ2lcgO5YKxa5xwRrQdpTVYup2hHwSD85rUtkoaCDPPzyx3BTbCvGMf7MkIPR4A/UHH0h+/pA+fGfElECzkZXqBNLYWrEnRIlsI36bjXBITnuGl/l6Vhzazjgc0xGjJcGBRenP5nqxN9Jw8vbDGgjmTxFMmbwIDAQAB" )

; --- Public ASN info site (served by Caddy on proxy VM) ---
@       IN  AAAA  2a0c:b641:b50:2::40
www     IN  AAAA  2a0c:b641:b50:2::40

; --- Infrastructure network (2a0c:b641:b50:2::/64) ---
rtr     IN  AAAA  2a0c:b641:b50:2::1
dns     IN  AAAA  2a0c:b641:b50:2::10
api     IN  AAAA  2a0c:b641:b50:2::20
web     IN  AAAA  2a0c:b641:b50:2::30
proxy   IN  AAAA  2a0c:b641:b50:2::40
vault   IN  AAAA  2a0c:b641:b50:2::40
vault-node IN AAAA 2a0c:b641:b50:2::c0
mon     IN  AAAA  2a0c:b641:b50:2::50
vpn     IN  AAAA  2a0c:b641:b50:2::60
xoa     IN  AAAA  2a0c:b641:b50:2::70
irc     IN  AAAA  2a0c:b641:b50:2::80
mail    IN  A     51.91.236.215
mail    IN  AAAA  2a0c:b641:b50:2::90
noc     IN  AAAA  2a0c:b641:b50:2::a0
log     IN  AAAA  2a0c:b641:b50:2::b0
ci      IN  AAAA  2a0c:b641:b50:2::d0
netproxy IN AAAA  2a0c:b641:b50:2::e0
loop    IN  AAAA  2a0c:b641:b50:2::f0
soc     IN  AAAA  2a0c:b641:b50:2::100

; --- Core routers — overlay loopback addresses ---
cr1-nl1 IN  AAAA  2a0c:b641:b50::a
cr1-de1 IN  AAAA  2a0c:b641:b50::b
cr1-ch1 IN  AAAA  2a0c:b641:b50::c
