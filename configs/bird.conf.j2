# /etc/bird/bird.conf — Hyrule Cloud BGP router (BIRD 2)
# Deploy to: rtr VM
# IPv6-only — no IPv4 routing internally.
#
# AS215932, prefix 2a0c:b641:b50::/44
#
# Variables to fill:
#   {{ router_id }}  — Router ID (use a 32-bit identifier, e.g. 0.0.215.932 or similar)

log syslog all;
router id {{ router_id | default('10.215.9.32') }};

# Router ID must be IPv4-format even for IPv6-only BIRD.
# Use a recognizable dummy like 10.215.9.32 (from ASN 215932).

protocol device {
    scan time 10;
}

protocol direct {
    ipv6;
    interface "eth0", "eth1", "eth2";  # transit, infra, vm
}

protocol kernel {
    ipv6 {
        export all;
        import all;
    };
    learn;
    merge paths on;
}

# Default route via firewall
protocol static default6 {
    ipv6;
    route ::/0 via 2a0c:b641:b50:1::1;  # fw transit address
}

# --- Filters ---
filter export_transit {
    # Announce our /44 aggregate
    if net = 2a0c:b641:b50::/44 then accept;
    reject;
}

filter import_transit {
    # Accept default + full table from transit
    accept;
}

# Static route for aggregate (ensures it's always in the table for BGP export)
protocol static aggregate {
    ipv6;
    route 2a0c:b641:b50::/44 blackhole;
}

